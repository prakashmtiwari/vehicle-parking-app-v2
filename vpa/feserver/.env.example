# Frontend environment example for Vite builds
# Set `VITE_API_BASE_URL` to the public URL the browser should use to reach the backend.
# When building in Kubernetes, set this to the externally reachable host (ingress / loadbalancer).

VITE_API_BASE_URL=http://backend.example.com:5000

# Public path prefix for the app (optional)
VITE_PUBLIC_PATH=/

# App metadata
VITE_APP_TITLE=ParkApp

# Optional token prefix for localStorage (frontend uses `token_<username>` by default)
VITE_TOKEN_PREFIX=token_
